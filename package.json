{
  "name": "habit-flow-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:vite\"",
    "dev:vite": "vite",
    "dev:server": "NODE_OPTIONS='--no-warnings' tsx watch src/server/index.ts",
    "dev:all": "npm run dev",
    "build": "tsc -b && vite build",
    "start": "tsx src/server/index.ts",
    "lint": "eslint .",
    "lint:beta": "eslint \"src/server/**/*.ts\" \"src/shared/**/*.ts\" \"src/domain/**/*.ts\" --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.ts\" --max-warnings 999",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:beta": "vitest run --config vitest.config.ts src/server/routes/__tests__/entriesOnly.invariants.test.ts src/server/routes/__tests__/goals.entriesDerived.test.ts src/server/routes/__tests__/routines.completion-guardrail.test.ts src/server/routes/__tests__/auth.integration.test.ts src/server/routes/__tests__/auth.identity.test.ts src/server/middleware/identity.test.ts src/server/__tests__/noDayLogImports.test.ts src/server/routes/__tests__/progress.overview.test.ts src/server/repositories/__tests__/habitEntryRepository.guardrails.test.ts",
    "verify": "bash scripts/verify.sh",
    "compare:legacy-reads": "tsx scripts/compare-legacy-vs-canonical.ts",
    "check:invariants": "tsx scripts/check-invariants.ts",
    "seed:emotion": "tsx scripts/seed-emotion-regulation.ts",
    "seed:fitness": "tsx scripts/seed-fitness.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/multer": "^2.0.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "lucide-react": "^0.555.0",
    "mongodb": "^7.0.0",
    "multer": "^2.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-tooltip": "^5.30.0",
    "recharts": "^3.5.0",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "mongodb-memory-server": "^11.0.1",
    "postcss": "^8.5.6",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.18",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.15"
  }
}
